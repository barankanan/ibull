PRINT_BRIDGE_HOST=127.0.0.1
PRINT_BRIDGE_PORT=3001
PRINT_BRIDGE_PRINTER_QUEUE=Thermal58
PRINT_BRIDGE_PAPER_WIDTH_MM=58
PRINT_BRIDGE_CHARS_PER_LINE=32
PRINT_BRIDGE_ENCODING=cp857
PRINT_BRIDGE_CODEPAGE=13
PRINT_BRIDGE_RENDER_MODE=image
PRINT_BRIDGE_RASTER_CHUNK_HEIGHT=256
PRINT_BRIDGE_ALLOWED_ORIGINS=https://ibul-ecommerce.web.app,http://localhost,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:3000
PRINT_BRIDGE_HEALTHCHECK_QUEUE=true
PRINT_BRIDGE_CUT_MODE=partial

# Transport mode: auto (USB first, CUPS fallback) | usb (USB only) | cups (CUPS only)
PRINT_BRIDGE_TRANSPORT=auto

# Optional: target a specific USB printer by vendor and product ID (hex).
# Leave blank for auto-discovery (first USB Printer-class device found).
# Find IDs with: system_profiler SPUSBDataType  (macOS)
#   or: lsusb  (Linux)
# On Windows, PRINT_BRIDGE_PRINTER_QUEUE should be the installed printer name
# shown by "Get-Printer" or GET /printers. USB VID/PID targeting is optional.
PRINT_BRIDGE_USB_VENDOR_ID=
PRINT_BRIDGE_USB_PRODUCT_ID=

# Centralized print-station queue consumer
PRINT_STATION_ENABLED=false
PRINT_STATION_RESTAURANT_ID=
PRINT_STATION_SUPABASE_URL=
PRINT_STATION_SUPABASE_ANON_KEY=
PRINT_STATION_ACCESS_TOKEN=
PRINT_STATION_REFRESH_TOKEN=
PRINT_STATION_USER_ID=
PRINT_STATION_DEVICE_NAME=Ibul Print Station
PRINT_STATION_DEVICE_PLATFORM=
PRINT_STATION_RECEIPT_PRINTER_ID=
PRINT_STATION_RECEIPT_PRINTER_NAME=
PRINT_STATION_KITCHEN_PRINTER_ID=
PRINT_STATION_KITCHEN_PRINTER_NAME=
PRINT_STATION_POLL_INTERVAL_MS=2500
PRINT_STATION_HEARTBEAT_INTERVAL_MS=15000
PRINT_STATION_MAX_RETRY_COUNT=2
