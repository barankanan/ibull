NEXT_PUBLIC_SUPABASE_URL=
# server-action (default, browser-safe) | api (requires RESTAURANT_API_SECRET header) | mock-local
NEXT_PUBLIC_RESTAURANT_CLIENT_ADAPTER=server-action
SUPABASE_SERVICE_ROLE_KEY=
# Required when RESTAURANT_DATA_SOURCE=supabase and using HTTP /api/restaurant/* routes.
RESTAURANT_API_SECRET=
RESTAURANT_DATA_SOURCE=mock
RESTAURANT_VENUE_ID=venue-demo
