# Copy this file to `.env` and fill it with real values locally.
# Never commit `.env`, Firebase config files, keystores, or service-role keys.

# ibul_app / root app
IBUL_SUPABASE_URL=https://your-project.supabase.co
IBUL_SUPABASE_ANON_KEY=your-ibul-anon-key
IBUL_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
IBUL_GOOGLE_SERVER_CLIENT_ID=your-google-server-client-id.apps.googleusercontent.com

IBUL_FIREBASE_PROJECT_ID=your-firebase-project-id
IBUL_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
IBUL_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
IBUL_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

IBUL_FIREBASE_WEB_API_KEY=your-firebase-web-api-key
IBUL_FIREBASE_WEB_APP_ID=your-firebase-web-app-id
IBUL_FIREBASE_WEB_MEASUREMENT_ID=your-firebase-web-measurement-id

IBUL_FIREBASE_ANDROID_API_KEY=your-firebase-android-api-key
IBUL_FIREBASE_ANDROID_APP_ID=your-firebase-android-app-id

IBUL_FIREBASE_IOS_API_KEY=your-firebase-ios-api-key
IBUL_FIREBASE_IOS_APP_ID=your-firebase-ios-app-id
IBUL_FIREBASE_IOS_BUNDLE_ID=com.example.ibul

IBUL_FIREBASE_MACOS_API_KEY=your-firebase-macos-api-key
IBUL_FIREBASE_MACOS_APP_ID=your-firebase-macos-app-id
IBUL_FIREBASE_MACOS_BUNDLE_ID=com.example.ibul

# Satıcı Windows installer (GitHub Release; override for local/dev builds)
# IBUL_SELLER_DESKTOP_WINDOWS_DOWNLOAD_URL=https://github.com/barankanan/ibull/releases/download/v1.0.2-windows-seller/IbulSellerSetup.exe

# ihiz_web
IHIZ_SUPABASE_URL=https://your-project.supabase.co
IHIZ_SUPABASE_ANON_KEY=your-ihiz-anon-key

# Optional test-only placeholders
TEST_SUPABASE_URL=https://example.supabase.co
TEST_SUPABASE_ANON_KEY=test-anon-key
