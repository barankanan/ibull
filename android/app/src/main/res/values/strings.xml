import 'dart:async';
import 'dart:io' as io;
import 'package:flutter/foundation.dart';
import 'package:flutter/material.dart';
import 'package:flutter/scheduler.dart';
import 'core/constants.dart';
import 'screens/home_screen.dart';

void main() {
  WidgetsFlutterBinding.ensureInitialized();

  debugPrint('Starting IBUL App. PID: ${io.pid}, OS: ${io.Platform.operatingSystem}');

  // Global Flutter error handler (shows errors in terminal)
  FlutterError.onError = (FlutterErrorDetails details) {
    FlutterError.dumpErrorToConsole(details);
    debugPrint('Unhandled Flutter error: ${details.exception}');
  };

  // Informative debug message on start (hot restart will re-run this)
  assert(() {
    debugPrint(
      'App is running in DEBUG mode. Start with ./scripts/run.sh or flutter run -d <deviceId>, then press "r" (hot reload) or "R" (hot restart) in this terminal.'
    );
    return true;
  }());

  // Catch uncaught zone errors (useful for async exceptions)
  runZonedGuarded(() {
    runApp(const MyApp());
  }, (error, stack) {
    debugPrint('Uncaught zone error: $error');
    debugPrintStack(stackTrace: stack);
  });
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'IBUL App',
      theme: ThemeData(
        useMaterial3: true,
        primaryColor: AppColors.primary,
        colorScheme: ColorScheme.fromSeed(
          seedColor: AppColors.primary,
          primary: AppColors.primary,
        ),
        scaffoldBackgroundColor: AppColors.background,
      ),
      // Wrap HomeScreen so we can detect hot reload and show status
      home: const HomeWrapper(),
    );
  }
}

// Wrapper that logs hot reloads and prints heartbeat to terminal
class HomeWrapper extends StatefulWidget {
  const HomeWrapper({super.key});

  @override
  State<HomeWrapper> createState() => _HomeWrapperState();
}

class _HomeWrapperState extends State<HomeWrapper> {
  String lastReassemble = 'never';
  Timer? _heartbeatTimer;
  bool _showDebugPanel = false;

  // New: deferred load flag and watchdog
  bool _loadedHome = false;
  int _lastFrameMillis = DateTime.now().millisecondsSinceEpoch;
  Timer? _watchdogTimer;
  bool _showUnresponsive = false;

  bool _startupStuck = false;
  Timer? _startupTimer;

  @override
  void initState() {
    super.initState();

    // Startup watchdog: if UI not loaded within 20s, show hint overlay and log
    _startupTimer = Timer(const Duration(seconds: 20), () {
      if (!_loadedHome && mounted) {
        setState(() => _startupStuck = true);
        debugPrint('Startup appears stuck: HomeScreen not loaded within 20s. Check terminal for build/runtime errors.');
      }
    });

    // Defer heavy HomeScreen build to next microtask to avoid blocking restart
    Future.microtask(() {
      if (mounted) {
        setState(() => _loadedHome = true);
        debugPrint('Deferred HomeScreen load completed');
        // cancel startup timer if started successfully
        _startupTimer?.cancel();
      }
    });

    // More frequent heartbeat
    _heartbeatTimer = Timer.periodic(const Duration(seconds: 5), (_) {
      debugPrint('App heartbeat: ${DateTime.now().toIso8601String()}');
    });

    // Frame callback updates last frame time
    SchedulerBinding.instance.addPersistentFrameCallback((_) {
      _lastFrameMillis = DateTime.now().millisecondsSinceEpoch;
      if (_showUnresponsive) {
        // recovered
        setState(() => _showUnresponsive = false);
        debugPrint('App responsiveness recovered at ${DateTime.now().toIso8601String()}');
      }
    });

    // Watchdog: if no frame for > 4000ms, mark as unresponsive
    _watchdogTimer = Timer.periodic(const Duration(milliseconds: 1000), (_) {
      final delta = DateTime.now().millisecondsSinceEpoch - _lastFrameMillis;
      if (delta > 4000 && !_showUnresponsive) {
        setState(() => _showUnresponsive = true);
        debugPrint('App appears unresponsive. No frames for ${delta}ms');
      }
    });
  }

  @override
  void dispose() {
    _heartbeatTimer?.cancel();
    _watchdogTimer?.cancel();
    _startupTimer?.cancel();
    super.dispose();
  }

  // Called on hot reload (reassemble)
  @override
  void reassemble() {
    super.reassemble();
    final now = DateTime.now().toIso8601String();
    setState(() {
      lastReassemble = now;
    });
    debugPrint('Hot reload / reassemble at $now');
  }

  void _triggerTestError() {
    // Throw inside a microtask so zone handler can catch it
    Future.microtask(() {
      throw StateError('Test exception triggered by user');
    });
  }

  // New: print helpful run/debug commands to terminal
  void _printRunCommands() {
    debugPrint('--- RUN / DEBUG COMMANDS ---');
    debugPrint('List devices: flutter devices');
    debugPrint('Run on specific device: flutter run -d <deviceId>');
    debugPrint('Or use script: ./scripts/run.sh --name "iphone11"');
    debugPrint('After app starts, press "r" for hot reload or "R" for hot restart in the SAME terminal.');
    debugPrint('---------------------------');
  }

  @override
  Widget build(BuildContext context) {
    return Stack(
      children: [
        // Use deferred loading: show a lightweight placeholder until _loadedHome is true
        if (_loadedHome)
          const HomeScreen()
        else
          const Scaffold(
            body: Center(child: CircularProgressIndicator()),
          ),

        // If startup stuck, show clear instructions to check terminal / device
        if (_startupStuck)
          Positioned.fill(
            child: Container(
              color: Colors.black87,
              alignment: Alignment.center,
              padding: const EdgeInsets.all(24),
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  const Icon(Icons.warning_amber_rounded, color: Colors.white, size: 48),
                  const SizedBox(height: 12),
                  const Text(
                    'Uygulama başlangıcı tamamlanmadı.\nLütfen terminaldeki çıktıyı kontrol edin veya cihazın hazır olduğundan emin olun.',
                    textAlign: TextAlign.center,
                    style: TextStyle(color: Colors.white),
                  ),
                  const SizedBox(height: 12),
                  ElevatedButton(
                    onPressed: () {
                      debugPrint('User asked to print more debug hints to terminal.');
                      debugPrint('Hint: run ./scripts/run.sh OR flutter run -d <deviceId>');
                    },
                    child: const Text('Debug İpuçlarını Yaz'),
                  ),
                ],
              ),
            ),
          ),

        // Small overlay showing last hot reload time
        Positioned(
          top: 12,
          right: 12,
          child: Container(
            padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 6),
            decoration: BoxDecoration(
              color: Colors.black54,
              borderRadius: BorderRadius.circular(6),
            ),
            child: Text(
              'Reload: $lastReassemble',
              style: const TextStyle(color: Colors.white, fontSize: 11),
            ),
          ),
        ),

        // Debug panel (toggleable)
        if (_showDebugPanel || kDebugMode)
          Positioned(
            left: 12,
            bottom: 12,
            right: 12,
            child: Material(
              color: Colors.black87,
              borderRadius: BorderRadius.circular(8),
              child: Padding(
                padding: const EdgeInsets.all(12),
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      'DEBUG PANEL',
                      style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold),
                    ),
                    const SizedBox(height: 8),
                    Text(
                      '1) Start app: ./scripts/run.sh veya flutter run -d <deviceId>\n'
                      '2) Uygulama başladıktan sonra terminalde "r" (hot reload) veya "R" (hot restart) kullanın\n'
                      '3) Terminal loglarını kontrol edin; hatalar burada yazılacaktır.',
                      style: TextStyle(color: Colors.white70, fontSize: 12),
                    ),
                    const SizedBox(height: 8),
                    Row(
                      children: [
                        ElevatedButton(
                          onPressed: _triggerTestError,
                          child: const Text('Trigger Test Exception'),
                        ),
                        const SizedBox(width: 8),
                        ElevatedButton(
                          onPressed: () {
                            debugPrint('Debug hint: run flutter attach or use IDE debug; press r/R for reload/restart.');
                          },
                          child: const Text('Log Hint'),
                        ),
                        const SizedBox(width: 8),
                        // New button
                        ElevatedButton(
                          onPressed: _printRunCommands,
                          child: const Text('Print Run Commands'),
                        ),
                      ],
                    ),
                  ],
                ),
              ),
            ),
          ),

        // Toggle button
        Positioned(
          top: 12,
          left: 12,
          child: FloatingActionButton.small(
            mini: true,
            onPressed: () => setState(() => _showDebugPanel = !_showDebugPanel),
            backgroundColor: Colors.black54,
            child: Icon(_showDebugPanel ? Icons.bug_report : Icons.bug_report_outlined),
          ),
        ),

        // Unresponsive overlay
        if (_showUnresponsive)
          Positioned.fill(
            child: Container(
              color: Colors.black54,
              alignment: Alignment.center,
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  const Icon(Icons.error_outline, color: Colors.white, size: 48),
                  const SizedBox(height: 8),
                  Text(
                    'App unresponsive\nNo UI frames for a few seconds',
                    textAlign: TextAlign.center,
                    style: const TextStyle(color: Colors.white),
                  ),
                  const SizedBox(height: 12),
                  ElevatedButton(
                    onPressed: () {
                      // Try a soft recovery: request a rebuild
                      if (mounted) setState(() {});
                      debugPrint('User requested soft recovery');
                    },
                    child: const Text('Try Recover'),
                  ),
                ],
              ),
            ),
          ),
      ],
    );
  }
}