                      _buildBadgeItem(Icons.chat_bubble, 'Hızlı Mesaj!', Colors.purple),
                    ],
                  ),
                ],
              ),
            ),
          ),
          const SizedBox(height: 20),

          // Satıcı Videoları
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 16.0),
