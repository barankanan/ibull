                      },
                    ),
                  ),
                ],
              ),
            ),
          ),
          const SizedBox(height: 20),

          // İstatistikler (Kargo, Konum, Cevap Hızı)
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 16.0),
            child: Row(
              children: [
                Expanded(child: _buildStatCard(Icons.local_shipping, 'Kargo Süresi', '5 Saat')),
                const SizedBox(width: 12),
                Expanded(child: _buildStatCard(Icons.location_on, 'Satıcı Konumu', 'Hatay / Antakya')),
                const SizedBox(width: 12),
                Expanded(child: _buildStatCard(Icons.message, 'Cevap Verme Hızı', '1 Saat')),
              ],
            ),
          ),
          const SizedBox(height: 20),

          // Satıcı Puanlaması
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 16.0),
            child: Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: Colors.grey[100],
                borderRadius: BorderRadius.circular(12),
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const Text('Satıcı Puanlaması', style: TextStyle(fontSize: 14, fontWeight: FontWeight.bold, color: Colors.black87)),
                  const SizedBox(height: 16),
                  Row(
                    children: [
                      // Logo
                      Container(
                        width: 80,
                        height: 80,
                        decoration: BoxDecoration(
                          color: Colors.white,
                          borderRadius: BorderRadius.circular(12),
                        ),
                        child: Center(
                          child: Text(
                            widget.business['name'] == 'Arçelik' ? 'Arçelik' : widget.business['logo'],
                            style: TextStyle(
                              fontWeight: FontWeight.w900,
                              color: widget.business['name'] == 'Arçelik' ? Colors.red : AppColors.primary,
                              fontSize: widget.business['name'] == 'Arçelik' ? 16 : 32,
                            ),
                          ),
                        ),
                      ),
                      const SizedBox(width: 16),
                      // Rating Bars
                      Expanded(
                        child: Column(
                          children: [
                            _buildRatingBar('5 Yıldız', 310, 570),
                            _buildRatingBar('4 Yıldız', 110, 570),
                            _buildRatingBar('3 Yıldız', 80, 570),
                            _buildRatingBar('2 Yıldız', 20, 570),
                            _buildRatingBar('1 Yıldız', 60, 570),
                          ],
                        ),
                      ),
                    ],
                  ),
                  const SizedBox(height: 12),
                  Row(
                    children: [
                      const Text('580 Kişi', style: TextStyle(fontSize: 12, color: Colors.black54)),
                      const Spacer(),
                      const Text('4.2', style: TextStyle(fontSize: 22, fontWeight: FontWeight.bold, color: Colors.black87)),
                      const SizedBox(width: 8),
                      Row(
                        children: List.generate(5, (index) {
                          return Icon(
                            index < 4 ? Icons.star : Icons.star_border,
                            color: Colors.amber,
                            size: 20,
