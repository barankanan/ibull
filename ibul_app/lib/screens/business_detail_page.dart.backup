                      ),
                    ),
                    const SizedBox(width: 8),
                    // Share Button
                    Container(
                      width: 40,
                      height: 40,
                      decoration: const BoxDecoration(
                        color: Colors.white,
                        shape: BoxShape.circle,
                      ),
                      child: IconButton(
                        icon: const Icon(Icons.share, color: AppColors.primary, size: 20),
                        onPressed: () {},
                        padding: EdgeInsets.zero,
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 12),
                // "Bugün Kargoda!" Banner
                Row(
                  children: [
                    const Icon(Icons.local_shipping, color: Colors.white, size: 18),
                    const SizedBox(width: 8),
                    const Text(
