        },
        child: Container(
          padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
          decoration: BoxDecoration(
            color: Colors.white,
            borderRadius: BorderRadius.circular(8),
            border: Border.all(color: Colors.grey[300]!),
          ),
          child: Row(
            children: [
              // Store Logo
              Container(
                width: 32,
                height: 32,
                decoration: BoxDecoration(
                  color: AppColors.primary.withOpacity(0.1),
                  borderRadius: BorderRadius.circular(6),
                ),
                child: Center(
                  child: Text(
                    widget.product.brand[0],
                    style: const TextStyle(
                      fontWeight: FontWeight.bold,
                      color: AppColors.primary,
                      fontSize: 16,
                    ),
                  ),
                ),
              ),
              const SizedBox(width: 8),
              // Store Name - Flexible with overflow handling
              Flexible(
                child: Text(
                  widget.product.brand,
                  style: const TextStyle(
                    fontSize: 13,
                    fontWeight: FontWeight.bold,
                    color: AppColors.primary,
                  ),
                  maxLines: 1,
                  overflow: TextOverflow.ellipsis,
                ),
              ),
              const SizedBox(width: 6),
              // Rating Badge
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
                decoration: BoxDecoration(
                  color: Colors.green,
                  borderRadius: BorderRadius.circular(8),
                ),
                child: Text(
                  widget.product.rating.toStringAsFixed(1),
                  style: const TextStyle(
                    color: Colors.white,
                    fontSize: 10,
                    fontWeight: FontWeight.bold,
                  ),
                ),
              ),
              const SizedBox(width: 6),
              const Icon(Icons.verified, color: Colors.blue, size: 14),
              const SizedBox(width: 4),
              const Icon(Icons.arrow_forward_ios, size: 10, color: Colors.grey),
              const Spacer(),
              const Spacer(),
              // Takip Et
              OutlinedButton(
                onPressed: () {
                  setState(() {
                    _isFollowing = !_isFollowing;
                  });
                  ScaffoldMessenger.of(context).showSnackBar(
                    SnackBar(
                      content: Text(_isFollowing ? 'Mağaza takip edildi' : 'Takip bırakıldı'),
                      duration: const Duration(seconds: 2),
                      backgroundColor: _isFollowing ? Colors.green : Colors.grey[700],
                    ),
                  );
                },
                style: OutlinedButton.styleFrom(
                  side: const BorderSide(color: AppColors.primary, width: 1),
                  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(14)),
                  padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                  minimumSize: Size.zero,
                ),
                child: Text(
                  _isFollowing ? 'Takiptesin' : 'Takip Et',
                  style: const TextStyle(color: AppColors.primary, fontWeight: FontWeight.w600, fontSize: 11),
                ),
              ),
              const SizedBox(width: 8),
              // Satıcıya Sor
              ElevatedButton(
                onPressed: () {
                  Navigator.push(
                    context,
                    MaterialPageRoute(
                      builder: (context) => ChatPage(
                        seller: {
                          'name': 'Arçelik',
                          'logo': 'A',
                        },
                        product: {
                          'name': widget.product.name,
                          'image': widget.product.images.isNotEmpty ? widget.product.images[0] : null,
                          'rating': '4.8',
                        },
                      ),
                    ),
                  );
                },
                style: ElevatedButton.styleFrom(
                  backgroundColor: AppColors.primary,
                  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(14)),
                  padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
                  elevation: 0,
                  minimumSize: Size.zero,
                ),
                child: const Text(
                  'Satıcıya Sor',
                  style: TextStyle(color: Colors.white, fontWeight: FontWeight.w600, fontSize: 11),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildProductOptions() {
    if (_variantOptions.isEmpty) {
      return const SizedBox.shrink();
    }
    
    return Padding(
      padding: const EdgeInsets.symmetric(horizontal: 16.0),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Ürün Seçenekleri',
            style: TextStyle(fontSize: 15, fontWeight: FontWeight.bold, color: Colors.black87),
          ),
          const SizedBox(height: 10),
          GestureDetector(
            onTap: () => _showProductVariantsBottomSheet(),
            child: _buildOptionCard(
              icon: Icons.check_circle_outline,
              title: 'Seç',
              subtitle: _getSelectedVariantsText(),
              trailing: Icons.arrow_forward_ios,
              borderColor: AppColors.primary,
              isLarge: true,
            ),
          ),
          const SizedBox(height: 6),
          GestureDetector(
            onTap: () => _showDeliveryOptionsBottomSheet(),
            child: _buildOptionCard(
              icon: Icons.local_shipping,
              title: 'KURYE TESLİMATI',
              subtitle: _appState.hasFastDelivery(widget.product)
                  ? 'Hızlı teslimat seçili'
                  : 'Tahmini 4 Saate adresinde',
              trailing: Icons.arrow_forward_ios,
            ),
          ),
          const SizedBox(height: 6),
          _buildOptionCard(
            icon: Icons.credit_card,
            title: 'Ayda 325 TL den başlayan taksitle',
            trailing: Icons.arrow_forward_ios,
          ),
          const SizedBox(height: 6),
          _buildOptionCard(
            icon: Icons.replay,
            title: 'İptal ve iade Koşulları',
            trailing: Icons.arrow_forward_ios,
          ),
        ],
      ),
    );
  }

  Widget _buildOptionCard({
    required IconData icon,
    required String title,
    String? subtitle,
    required IconData trailing,
    Color? borderColor,
    bool isLarge = false,
  }) {
    return Container(
      padding: const EdgeInsets.symmetric(
        horizontal: 12,
        vertical: 8,
      ),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: borderColor ?? Colors.grey[300]!),
      ),
      child: Row(
        children: [
          Icon(icon, color: AppColors.primary, size: isLarge ? 22 : 20),
          const SizedBox(width: 12),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  title,
                  style: TextStyle(
                    fontSize: isLarge ? 13 : 12,
                    fontWeight: isLarge ? FontWeight.w700 : FontWeight.w600,
                    color: Colors.black87,
                  ),
                ),
                if (subtitle != null) ...[
                  const SizedBox(height: 2),
                  Text(
                    subtitle,
                    style: TextStyle(fontSize: 10, color: Colors.grey[600]),
                  ),
                ],
              ],
            ),
          ),
          Icon(trailing, size: 14, color: Colors.grey[400]),
        ],
      ),
    );
  }

